@startuml
left to right direction

actor Administrateur as Admin
actor "Responsable RH" as RH
actor Encadrant as Supervisor
actor Stagiaire as Intern
actor Système as System

rectangle "Gestion des Stages OCP" {

  usecase "S'authentifier" as UC_Login
  usecase "Modifier mot de passe" as UC_Pwd
  usecase "Consulter mon profil" as UC_Profile

  usecase "Gérer les utilisateurs" as UC_Users
  usecase "Gérer les départements" as UC_Depts
  usecase "Gérer les rôles" as UC_Roles

  usecase "Créer offre de stage" as UC_CreateOffer
  usecase "Publier / Clôturer offre" as UC_PublishOffer
  usecase "Consulter les offres" as UC_ViewOffers

  usecase "Postuler" as UC_Apply
  usecase "Déposer documents" as UC_Docs
  usecase "Suivre ma candidature" as UC_TrackApp
  usecase "Modifier ma candidature" as UC_EditApp
  usecase "Examiner candidatures" as UC_ReviewApps
  usecase "Approuver candidature" as UC_Approve
  usecase "Refuser candidature" as UC_Reject
  usecase "Demander documents" as UC_ReqDocs

  usecase "Assigner encadrant" as UC_Assign
  usecase "Changer service" as UC_ChangeDept
  usecase "Suspendre stagiaire" as UC_Suspend

  usecase "Scanner QR présence" as UC_QR
  usecase "Consulter mes présences" as UC_MyAtt
  usecase "Consulter présences stagiaires" as UC_AllAtt

  usecase "Soumettre rapport" as UC_SubmitRpt
  usecase "Réviser rapport" as UC_ReviewRpt

  usecase "Évaluer stagiaire" as UC_Eval
  usecase "Consulter mon évaluation" as UC_MyEval

  usecase "Générer convention" as UC_Conv
  usecase "Signer convention" as UC_SignConv
  usecase "Générer certificat" as UC_Cert
  usecase "Télécharger certificat" as UC_DlCert

  usecase "Consulter notifications" as UC_Notif
  usecase "Consulter tableau de bord" as UC_Dash
  usecase "Consulter audit" as UC_Audit
  usecase "Exporter données" as UC_Export
}

' === INCLUDE : tous les UC protégés incluent l'authentification ===
UC_Users .> UC_Login : <<include>>
UC_Depts .> UC_Login : <<include>>
UC_Roles .> UC_Login : <<include>>
UC_CreateOffer .> UC_Login : <<include>>
UC_PublishOffer .> UC_Login : <<include>>
UC_ViewOffers .> UC_Login : <<include>>
UC_Apply .> UC_Login : <<include>>
UC_Docs .> UC_Login : <<include>>
UC_TrackApp .> UC_Login : <<include>>
UC_EditApp .> UC_Login : <<include>>
UC_ReviewApps .> UC_Login : <<include>>
UC_Approve .> UC_Login : <<include>>
UC_Reject .> UC_Login : <<include>>
UC_ReqDocs .> UC_Login : <<include>>
UC_Assign .> UC_Login : <<include>>
UC_ChangeDept .> UC_Login : <<include>>
UC_Suspend .> UC_Login : <<include>>
UC_QR .> UC_Login : <<include>>
UC_MyAtt .> UC_Login : <<include>>
UC_AllAtt .> UC_Login : <<include>>
UC_SubmitRpt .> UC_Login : <<include>>
UC_ReviewRpt .> UC_Login : <<include>>
UC_Eval .> UC_Login : <<include>>
UC_MyEval .> UC_Login : <<include>>
UC_Conv .> UC_Login : <<include>>
UC_SignConv .> UC_Login : <<include>>
UC_Cert .> UC_Login : <<include>>
UC_DlCert .> UC_Login : <<include>>
UC_Notif .> UC_Login : <<include>>
UC_Dash .> UC_Login : <<include>>
UC_Audit .> UC_Login : <<include>>
UC_Export .> UC_Login : <<include>>
UC_Profile .> UC_Login : <<include>>
UC_Pwd .> UC_Login : <<include>>

' === EXTEND : cas optionnels ===
UC_EditApp .> UC_TrackApp : <<extend>>
UC_Approve .> UC_ReviewApps : <<extend>>
UC_Reject .> UC_ReviewApps : <<extend>>
UC_ReqDocs .> UC_ReviewApps : <<extend>>
UC_PublishOffer .> UC_CreateOffer : <<extend>>
UC_MyAtt .> UC_QR : <<extend>>
UC_DlCert .> UC_Cert : <<extend>>
UC_AllAtt .> UC_QR : <<extend>>

' === INCLUDE : dépendances métier obligatoires ===
UC_Assign .> UC_Approve : <<include>>
UC_Suspend .> UC_Assign : <<include>>
UC_ChangeDept .> UC_Assign : <<include>>
UC_Conv .> UC_Assign : <<include>>
UC_Cert .> UC_Eval : <<include>>
UC_SignConv .> UC_Conv : <<include>>
UC_ReviewRpt .> UC_SubmitRpt : <<include>>
UC_Docs .> UC_Apply : <<include>>
UC_Export .> UC_Dash : <<include>>
UC_Profile .> UC_Users : <<extend>>

